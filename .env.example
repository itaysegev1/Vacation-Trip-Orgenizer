# ─────────────────────────────────────────────────────────────
# Firebase Web App config — copy this file to `.env` and fill in.
# Get these values from Firebase Console → Project settings →
# "Your apps" → Web app → SDK setup and configuration → Config.
# These are NOT secrets (they ship to the browser); security is
# enforced by Firestore rules + Email/Password auth.
# ─────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MSG_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional — enables Firebase Analytics if present
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: set to "true" to preview the app with in-memory sample data
# and NO backend (no login, nothing persists). Great for a first look.
# Leave empty / false for the real synced app.
VITE_DEMO=

# Auth allow-list — comma-separated emails allowed to sign in (and generates firestore.rules).
VITE_ALLOWED_EMAILS=you@gmail.com,partner@gmail.com
